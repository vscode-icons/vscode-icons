{
  "compilerOptions": {
    "lib": ["es2022"],
    "module": "node16",
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "out",
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strictFunctionTypes": false,
    "strictNullChecks": false,
    "target": "es6"
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
